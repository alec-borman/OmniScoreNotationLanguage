### 3. `src/parser.js`
This is the heart of OmniScore. It implements the **Definition Schema** and the **Sticky Attribute Logic**.

```javascript
// src/parser.js
import { parsePitch, parseDuration } from './theory.js';

export class OmniParser {
  constructor(source) {
    this.source = source;
    this.lines = source.split(/\r?\n/);
    this.ast = {
      meta: {},
      definitions: {},
      measures: []
    };
    
    // State Machine Memory
    this.state = {
      lastDuration: ':4', // Default quarter note
      lastOctaves: {}     // Per-track memory
    };
  }

  parse() {
    let currentMeasure = null;

    for (let line of this.lines) {
      line = line.trim();
      if (!line || line.startsWith('%%')) continue;

      // 1. Meta Parsing
      if (line.startsWith('meta')) {
        // Simple regex for { key: value }
        const content = line.match(/{(.*)}/)[1];
        content.split(',').forEach(pair => {
          const [k, v] = pair.split(':').map(s => s.trim().replace(/"/g, ''));
          this.ast.meta[k] = v;
        });
        continue;
      }

      // 2. Definitions
      if (line.startsWith('def')) {
        // def vln "Violin" style=standard
        const parts = line.split(/\s+/);
        const id = parts[1];
        const style = line.match(/style=(\w+)/)[1];
        const nameMatch = line.match(/"([^"]+)"/);
        
        this.ast.definitions[id] = {
          id,
          name: nameMatch ? nameMatch[1] : id,
          style
        };
        this.state.lastOctaves[id] = 4; // Initialize at C4
        continue;
      }

      // 3. Measure Blocks
      if (line.startsWith('measure')) {
        const num = parseInt(line.split(' ')[1]);
        currentMeasure = { number: num, tracks: {} };
        this.ast.measures.push(currentMeasure);
        continue;
      }

      // 4. Track Events (Inside Measure)
      if (line.includes(':') && currentMeasure) {
        // vln: c4:4 e g |
        const [trackId, content] = line.split(/:(.+)/); // Split on first colon
        const eventsRaw = content.split('|')[0].trim().split(/\s+/);
        
        const events = eventsRaw.map(rawToken => {
            return this.processToken(trackId.trim(), rawToken);
        }).filter(e => e !== null);

        currentMeasure.tracks[trackId.trim()] = events;
      }
    }
    return this.ast;
  }

  processToken(trackId, token) {
    if (!token) return null;

    // Token Structure: Value:Duration.Modifiers
    // Regex splits "c4" and ":4.stc"
    const parts = token.match(/^([^:.]+)(:[0-9.]+)?(\..*)?$/);
    if (!parts) return null; // Logic fail safe

    let [_, input, durRaw, modRaw] = parts;

    // --- LOGIC: STICKY DURATION ---
    if (durRaw) {
      this.state.lastDuration = durRaw;
    } else {
      durRaw = this.state.lastDuration;
    }

    // --- LOGIC: INPUT TYPE HANDLING ---
    // Check definition style
    const def = this.ast.definitions[trackId];
    let data = {};

    if (def && def.style === 'tab') {
      // Input is Fret-String (0-6)
      data = { type: 'tab', value: input };
    } else if (def && def.style === 'grid') {
      // Input is Key (k)
      data = { type: 'grid', value: input };
    } else {
      // Default: Pitch
      // --- LOGIC: STICKY OCTAVE / INFERENCE ---
      // If input is just 'c', use memory. 
      // This simple CLI just parses what is there + defaults.
      data = { type: 'note', ...parsePitch(input, this.state.lastOctaves[trackId]) };
      if (data.oct) this.state.lastOctaves[trackId] = data.oct;
    }

    return {
      ...data,
      duration: parseDuration(durRaw),
      modifiers: modRaw ? modRaw.split('.').filter(s => s) : []
    };
  }
}
```

