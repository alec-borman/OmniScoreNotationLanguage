### 5. `bin/omniscore.js` (The CLI)
The glue that makes it runnable.

```javascript
#!/usr/bin/env node

import { program } from 'commander';
import fs from 'fs';
import { OmniParser } from '../src/parser.js';
import { OmniRenderer } from '../src/renderer.js';

program
  .name('omniscore')
  .description('Compile .omni text files to SVG notation')
  .version('1.0.0');

program.command('render')
  .argument('<file>', 'input .omni file')
  .option('-o, --out <file>', 'output filename', 'output.svg')
  .action((file, options) => {
    try {
      console.log(`🎵 Reading ${file}...`);
      const source = fs.readFileSync(file, 'utf-8');

      console.log('🧠 Parsing logic...');
      const parser = new OmniParser(source);
      const ast = parser.parse();

      console.log('🎨 Rendering SVG...');
      const renderer = new OmniRenderer(ast);
      const svg = renderer.generate();

      fs.writeFileSync(options.out, svg);
      console.log(`✅ Success! Rendered to ${options.out}`);
      
    } catch (e) {
      console.error('❌ Error:', e.message);
    }
  });

program.parse();
```

