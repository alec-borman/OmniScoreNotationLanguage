### 2. `src/theory.js`
Helper logic to handle the math of music (converting `c4` to an integer index for drawing).

```javascript
// src/theory.js

const NOTES = { c: 0, d: 1, e: 2, f: 3, g: 4, a: 5, b: 6 };

export function parsePitch(pitchStr, currentOctave = 4) {
  // Regex: matches "c", "#", "4"
  const match = pitchStr.match(/^([a-g])([#b]?)(-?\d*)$/i);
  if (!match) return null;

  const step = match[1].toLowerCase();
  const acc = match[2];
  let oct = match[3] ? parseInt(match[3]) : null;

  // Inference Logic (Sticky Octave)
  // If no octave provided, we'd theoretically find the closest.
  // For this lightweight CLI, if omitted, we default to currentOctave.
  if (oct === null) oct = currentOctave;

  return {
    step,
    acc,
    oct,
    // Calculate vertical index (C4 = 0)
    index: (oct - 4) * 7 + NOTES[step]
  };
}

export function parseDuration(durStr) {
  // :4. -> 1/4 * 1.5
  if (!durStr) return null;
  
  const baseMap = { '1': 4, '2': 2, '4': 1, '8': 0.5, '16': 0.25 };
  let val = durStr.replace(/\.|:/g, '');
  let dots = (durStr.match(/\./g) || []).length;
  
  let beats = baseMap[val] || 1;
  if (dots) beats *= 1.5;
  
  return { code: val, value: beats };
}
```

