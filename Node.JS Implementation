### 4. `src/renderer.js`
This converts the JSON Logic into the **Schematic SVG** style we designed. It creates a simple grid layout.

```javascript
// src/renderer.js

export class OmniRenderer {
  constructor(ast) {
    this.ast = ast;
    this.svg = [];
    this.config = {
      staffHeight: 60,
      measureWidth: 300,
      lineColor: '#E1E4E8',
      noteColor: '#24292E'
    };
  }

  generate() {
    // 1. Calculate Canvas Size
    const measureCount = this.ast.measures.length;
    const staffCount = Object.keys(this.ast.definitions).length;
    const width = measureCount * this.config.measureWidth + 100;
    const height = staffCount * 100 + 100;

    this.svg.push(`<svg viewBox="0 0 ${width} ${height}" xmlns="http://www.w3.org/2000/svg">`);
    this.svg.push(`<rect width="100%" height="100%" fill="white"/>`);
    this.svg.push(`<style>.txt { font-family: monospace; font-size: 12px; fill: #586069; }</style>`);

    // 2. Render Staves (The "Paper")
    let yOffset = 50;
    Object.values(this.ast.definitions).forEach(def => {
      this.renderStaffLines(def, yOffset, width);
      this.renderTrackLabel(def, yOffset);
      yOffset += 100;
    });

    // 3. Render Events (The "Ink")
    this.ast.measures.forEach((measure, mIndex) => {
      const xStart = 50 + (mIndex * this.config.measureWidth);
      
      // Draw Bar Lines
      this.svg.push(`<line x1="${xStart + this.config.measureWidth}" y1="50" x2="${xStart + this.config.measureWidth}" y2="${height-50}" stroke="#D1D5DA" stroke-width="2"/>`);

      let trackY = 50;
      Object.keys(this.ast.definitions).forEach(trackId => {
        const events = measure.tracks[trackId] || [];
        const def = this.ast.definitions[trackId];
        
        let cursorX = xStart + 20;
        
        events.forEach(ev => {
          this.renderEvent(ev, def, cursorX, trackY);
          // Advance Cursor based on duration (Simple linear mapping)
          // 4 beats = measureWidth
          const pxPerBeat = (this.config.measureWidth - 40) / 4;
          cursorX += ev.duration.value * pxPerBeat;
        });

        trackY += 100;
      });
    });

    this.svg.push('</svg>');
    return this.svg.join('\n');
  }

  renderStaffLines(def, y, width) {
    if (def.style === 'standard') {
      // 5 lines
      for (let i = 0; i < 5; i++) {
        this.svg.push(`<line x1="50" y1="${y + i*10}" x2="${width-50}" y2="${y + i*10}" stroke="${this.config.lineColor}" stroke-width="2"/>`);
      }
    } else if (def.style === 'tab') {
      // 6 lines
      for (let i = 0; i < 6; i++) {
        this.svg.push(`<line x1="50" y1="${y + i*10}" x2="${width-50}" y2="${y + i*10}" stroke="${this.config.lineColor}" stroke-width="1"/>`);
      }
    } else {
      // Grid: 1 line
      this.svg.push(`<line x1="50" y1="${y + 25}" x2="${width-50}" y2="${y + 25}" stroke="${this.config.lineColor}" stroke-width="1"/>`);
    }
  }

  renderTrackLabel(def, y) {
    this.svg.push(`<text x="40" y="${y + 25}" text-anchor="end" class="txt">${def.name}</text>`);
  }

  renderEvent(ev, def, x, y) {
    if (def.style === 'standard') {
      // Map Pitch Index to Y pixels
      // Center C (index 0) is at y + 50 (roughly middle C position logic for demo)
      // Higher pitch = Lower Y
      const yPos = (y + 50) - (ev.index * 5); // 5px per step
      this.svg.push(`<circle cx="${x}" cy="${yPos}" r="5" fill="${this.config.noteColor}"/>`);
      // Simple Stem
      this.svg.push(`<line x1="${x+5}" y1="${yPos}" x2="${x+5}" y2="${yPos-25}" stroke="${this.config.noteColor}" stroke-width="2"/>`);
    } 
    else if (def.style === 'tab') {
      // Value "0-6" -> String 6 is bottom line
      const [fret, str] = ev.value.split('-');
      const lineIndex = parseInt(str) - 1; 
      // Tab lines are inverted visually (Low E is bottom) usually, 
      // but for simple logic: line 0 = top.
      const yPos = y + (parseInt(str)-1)*10;
      
      this.svg.push(`<rect x="${x-5}" y="${yPos-5}" width="10" height="10" fill="white"/>`);
      this.svg.push(`<text x="${x}" y="${yPos+4}" text-anchor="middle" font-family="monospace" font-size="10" fill="purple">${fret}</text>`);
    }
    else {
      // Grid Hit
      this.svg.push(`<rect x="${x-5}" y="${y+20}" width="10" height="10" fill="${this.config.noteColor}"/>`);
    }
  }
}
